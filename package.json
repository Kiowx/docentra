{
  "name": "docentra",
  "version": "1.0.2",
  "description": "Wenshu Docentra - AI-powered document workspace for spreadsheets and writing",
  "author": "Developer",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite --mode electron",
    "build": "vite build",
    "build:check": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "pack": "vite build && electron-builder --win --x64 --dir",
    "dist": "vite build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.docentra.app",
    "productName": "文枢",
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "icon.ico"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "uuid": "^9.0.1",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.3"
  }
}
